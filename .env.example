# Anthropic API key for the AI-Ops diagnosis LLM (required)
ANTHROPIC_API_KEY=

# Slack incoming webhook URL for incident alerts (optional; incidents also go to stdout + incidents.log)
SLACK_WEBHOOK_URL=

# Postgres connection string. Default targets the docker-compose service.
DATABASE_URL=postgresql://jobwatch:jobwatch@localhost:5434/jobwatch

# Comma-separated tickers to ingest
TICKERS=GOOGL,AMZN,AAPL,NFLX,NVDA,ORCL

# Anthropic model used for diagnosis. Haiku for cost (~$0.02/incident), Sonnet for polish.
DIAGNOSIS_MODEL=claude-haiku-4-5-20251001

# Prometheus /metrics port exposed by the MCP server
METRICS_PORT=9100

# Alert threshold: if a job_runs row has rows_written below this, treat as anomaly.
ROWS_WRITTEN_THRESHOLD=3
